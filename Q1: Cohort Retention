WITH first_order AS (
    SELECT
        user_id,
        MIN(order_date) AS first_order_date
    FROM orders
    GROUP BY user_id
)
, retention AS (
    SELECT
        f.user_id,
        f.first_order_date,
        CASE 
            WHEN EXISTS (
                SELECT 1 
                FROM orders o
                WHERE o.user_id = f.user_id
                  AND o.order_date > f.first_order_date
                  AND o.order_date <= f.first_order_date + INTERVAL '30 days'
            ) THEN TRUE
            ELSE FALSE
        END AS retained_within_30_days
    FROM first_order f
)

SELECT *
FROM retention;
